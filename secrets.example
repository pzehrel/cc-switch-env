# cc-switch-env secrets 模板
# 复制此文件为 secrets，填入真实的 API key
#
# 命名规则: CCE_<PROVIDER>_TOKEN  (PROVIDER 为大写，连字符转下划线)
#
# 示例（下面的是假 key，请替换）：

# DeepSeek
CCE_DEEPSEEK_TOKEN="sk-your-deepseek-key"

# Kimi (Moonshot)
CCE_KIMI_TOKEN="sk-kimi-your-key"

# 智谱 GLM
CCE_GLM_TOKEN="your-glm-key"

# MiniMax
CCE_MINIMAX_TOKEN="sk-api-your-minimax-key"

# LiteLLM（本地代理）
CCE_LITELLM_TOKEN="sk-your-litellm-key"
