# cc-switch-env secrets template
# Copy this file to "secrets" and fill in your real API keys.
#
# Naming convention: CCE_<PROVIDER>_TOKEN
# (PROVIDER is uppercase, hyphens become underscores)
#
# The values below are examples — replace them.

# DeepSeek
CCE_DEEPSEEK_TOKEN="sk-your-deepseek-key"

# Kimi (Moonshot)
CCE_KIMI_TOKEN="sk-kimi-your-key"

# GLM (Zhipu)
CCE_GLM_TOKEN="your-glm-key"

# MiniMax
CCE_MINIMAX_TOKEN="sk-api-your-minimax-key"

# LiteLLM (local proxy)
CCE_LITELLM_TOKEN="sk-your-litellm-key"
