#!/usr/bin/env bash
# cc-switch-env — Claude Code environment switcher
# https://github.com/pzehrel/cc-switch-env

set -u -o pipefail

# ── XDG paths ──
CCSE_CONFIG="${CCSE_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/ccse}"
CCSE_DATA="${CCSE_DATA:-${XDG_DATA_HOME:-$HOME/.local/share}/ccse}"
: "${SECRETS:=$CCSE_CONFIG/secrets}"
PROVIDERS="${CCSE_CONFIG}/providers"
STATE="${CCSE_DATA}/state"
LAST="${CCSE_DATA}/last"
VARS_DIR="${CCSE_DATA}/vars"

# ── Utility functions ──

_load_secrets() {
    [ -f "$SECRETS" ] && . "$SECRETS"
}

_list_providers() {
    for f in "$PROVIDERS"/*.zsh; do
        [ -f "$f" ] || continue
        basename "$f" .zsh
    done
}

# Extract @alias annotation from a provider file
_extract_alias() {
    grep -oE '#[[:space:]]*@alias:[[:space:]]*[A-Za-z0-9_-]+' "$1" 2>/dev/null \
        | sed 's/.*@alias:[[:space:]]*//' \
        | head -1
}

# Resolve alias to provider name; returns the name unchanged if not an alias
_resolve_alias() {
    local name="$1"
    local file="$PROVIDERS/${name}.zsh"
    [ -f "$file" ] && { echo "$name"; return 0; }
    # Search all providers for @alias matching this name
    local resolved
    resolved=$(grep -l "^# @alias: ${name}$" "$PROVIDERS"/*.zsh 2>/dev/null | head -1)
    [ -n "$resolved" ] && { basename "$resolved" .zsh; return 0; }
    echo "$name"
}

# Extract all export variable names from a provider file (strategy A)
_extract_exports() {
    grep -oE '^[[:space:]]*export[[:space:]]+([A-Za-z_][A-Za-z0-9_]*)' "$1" 2>/dev/null \
        | sed 's/^[[:space:]]*export[[:space:]]*//'
}

# Extract @noreset annotations from a provider file (strategy B)
_extract_noreset() {
    grep -oE '#[[:space:]]*@noreset:[[:space:]]*.*' "$1" 2>/dev/null \
        | sed 's/.*@noreset:[[:space:]]*//' \
        | tr ' ' '\n' \
        | grep -v '^$'
}

# Full reset fallback: unset all known CC variables
_print_full_reset() {
    cat <<'EOF'
unset ANTHROPIC_API_KEY
unset ANTHROPIC_BASE_URL
unset ANTHROPIC_CUSTOM_HEADERS
unset ANTHROPIC_AUTH_TOKEN
unset ANTHROPIC_MODEL
unset ANTHROPIC_DEFAULT_HAIKU_MODEL
unset ANTHROPIC_DEFAULT_HAIKU_MODEL_NAME
unset ANTHROPIC_DEFAULT_SONNET_MODEL
unset ANTHROPIC_DEFAULT_SONNET_MODEL_NAME
unset ANTHROPIC_DEFAULT_OPUS_MODEL
unset ANTHROPIC_DEFAULT_OPUS_MODEL_NAME
unset CLAUDE_CODE_EFFORT_LEVEL
unset CLAUDE_CODE_SUBAGENT_MODEL
unset CLAUDE_CODE_AUTO_COMPACT_WINDOW
unset CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC
unset CLAUDE_CODE_ATTRIBUTION_HEADER
unset API_TIMEOUT_MS
EOF
}

# Precise reset: only unset variables declared by the previous provider (A + B)
_print_reset() {
    local prev_provider="${CCSE_CURRENT_PROVIDER:-}"
    local prev_file="$PROVIDERS/${prev_provider}.zsh"

    if [ -z "$prev_provider" ] || [ ! -f "$prev_file" ]; then
        _print_full_reset
        return
    fi

    local noreset
    noreset=$(_extract_noreset "$prev_file")

    while IFS= read -r var; do
        [ -z "$var" ] && continue
        if echo "$noreset" | grep -qxF "$var" 2>/dev/null; then
            continue
        fi
        echo "unset $var"
    done < <(_extract_exports "$prev_file")
}

# Output provider env vars (strategy C: source + capture)
_print_provider_env() {
    local name="$1"
    local file="$PROVIDERS/${name}.zsh"

    if [ ! -f "$file" ]; then
        echo "ccse: unknown provider '$name'" >&2
        printf "ccse: available: %s\n" "$(_list_providers | tr '\n' ' ')" >&2
        return 1
    fi

    _load_secrets

    # Source the provider file; ${CCE_*_TOKEN:?} style vars expand in-process
    { . "$file"; } 2>/tmp/ccse-provider-err.$$ || {
        echo "ccse: failed to load provider '$name'" >&2
        cat /tmp/ccse-provider-err.$$ >&2 2>/dev/null
        rm -f /tmp/ccse-provider-err.$$
        echo "ccse: check that required keys are set in $SECRETS" >&2
        return 1
    }
    rm -f /tmp/ccse-provider-err.$$

    # Print current values of variables declared by this provider
    local vars
    vars=$(_extract_exports "$file")
    local var value
    for var in $vars; do
        [ -z "$var" ] && continue
        eval "value=\${$var:-}"
        [ -n "$value" ] || continue
        printf "export %s='%s'\n" "$var" "$value"
    done
}

# ── Subcommands ──

cmd_init() {
    cat <<'WRAPPER'
# cc-switch-env wrapper
_ccse() {
  local cmd="${1:-}"
  if [ -z "$cmd" ]; then
    echo "ccse: usage: ccse <provider|ls|current|default>" >&2
    command ccse list >&2
    return 1
  fi
  case "$cmd" in
    ls|list)    command ccse list ;;
    current)    command ccse current ;;
    default)
      case "${2:-}" in
        -d) command ccse default -d ;;
        *)  eval "$(command ccse default "${2:-}")" ;;
      esac ;;
    *)          eval "$(command ccse _switch "$cmd")" ;;
  esac
}

alias ccse=_ccse
WRAPPER

    # Inline restore so init takes only one subprocess
    cmd_restore
}

cmd_list() {
    case "${1:-}" in
        --names)
            _list_providers
            ;;
        --aliases)
            for f in "$PROVIDERS"/*.zsh; do
                [ -f "$f" ] || continue
                _extract_alias "$f"
            done
            ;;
        *)
            local name alias
            for f in "$PROVIDERS"/*.zsh; do
                [ -f "$f" ] || continue
                name="$(basename "$f" .zsh)"
                alias=$(_extract_alias "$f")
                if [ -n "$alias" ]; then
                    echo "$name ($alias)"
                else
                    echo "$name"
                fi
            done
            ;;
    esac
}

cmd_switch() {
    local name="${1:-}"
    [ -z "$name" ] && { echo "ccse: usage: ccse <provider>" >&2; return 1; }

    # Resolve alias if needed
    name=$(_resolve_alias "$name")

    _print_reset
    _print_provider_env "$name" || return 1
    echo "export CCSE_CURRENT_PROVIDER='${name}'"

    mkdir -p "$(dirname "$LAST")"
    echo "$name" > "$LAST"
}

cmd_default() {
    if [ "${1:-}" = "-d" ]; then
        rm -f "$STATE"
        echo "ccse: default cleared (last used still preserved)" >&2
        return 0
    fi

    local name="${1:-}"
    [ -z "$name" ] && { echo "ccse: usage: ccse default <provider|-d>" >&2; return 1; }

    cmd_switch "$name" || return 1
    mkdir -p "$(dirname "$STATE")"
    echo "$name" > "$STATE"
    echo "ccse: default set to '$name'" >&2
}

cmd_restore() {
    [ -n "${CCSE_NO_RESTORE:-}" ] && return 0

    local provider

    # Three-tier fallback: state → last → first available
    if [ -f "$STATE" ]; then
        provider="$(cat "$STATE" 2>/dev/null)"
        if [ -n "$provider" ] && [ -f "$PROVIDERS/${provider}.zsh" ]; then
            _print_full_reset
            _print_provider_env "$provider"
            echo "export CCSE_CURRENT_PROVIDER='$provider'"
            return 0
        fi
    fi

    if [ -f "$LAST" ]; then
        provider="$(cat "$LAST" 2>/dev/null)"
        if [ -n "$provider" ] && [ -f "$PROVIDERS/${provider}.zsh" ]; then
            _print_full_reset
            _print_provider_env "$provider"
            echo "export CCSE_CURRENT_PROVIDER='$provider'"
            return 0
        fi
    fi

    # Fall back to first available provider
    provider="$(_list_providers | head -1)"
    if [ -n "$provider" ]; then
        _print_full_reset
        _print_provider_env "$provider"
        echo "export CCSE_CURRENT_PROVIDER='$provider'"
        return 0
    fi
}

cmd_current() {
    printf "provider: %s\n" "${CCSE_CURRENT_PROVIDER:-none}"
    printf "default : %s\n" "$(cat "$STATE" 2>/dev/null || echo none)"
    printf "last    : %s\n" "$(cat "$LAST" 2>/dev/null || echo none)"
}

# ── Entry point ──
case "${1:-}" in
    init)     cmd_init ;;
    list|ls)  cmd_list "${2:-}" ;;
    _switch)  cmd_switch "${2:-}" ;;
    default)  cmd_default "${2:-}" ;;
    restore)  cmd_restore ;;
    current)  cmd_current ;;
    *)
        echo "usage: ccse {init|list|current|default|restore}" >&2
        exit 1
        ;;
esac
